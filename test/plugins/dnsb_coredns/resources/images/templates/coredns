# Dockerfile for CoreDNS v{version}
# Auto-generated by DNS Builder

# The base image is now configurable by the Image class
FROM {base_image}

ENV DEBIAN_FRONTEND=noninteractive

# Install chsrc if mirror config uses 'auto'
{chsrc_install_setup}

# Optional mirror setup
{apt_mirror_setup}
{pip_mirror_setup}

# --- STAGE 1: Install Dependencies ---
{dep_packages}

# --- STAGE 2: Download CoreDNS Binary ---
WORKDIR /tmp
RUN apt-get update && apt-get install -y wget ca-certificates && \
    wget -q https://github.com/coredns/coredns/releases/download/v{version}/coredns_{version}_linux_amd64.tgz && \
    tar xzf coredns_{version}_linux_amd64.tgz && \
    mv coredns /usr/local/bin/ && \
    rm -f coredns_{version}_linux_amd64.tgz && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# --- STAGE 3: Configuration ---
RUN mkdir -p /etc/coredns && \
    mkdir -p /var/lib/coredns

# Create coredns user (optional, can run as root for simplicity)
RUN groupadd -r coredns && useradd -r -g coredns coredns && \
    chown -R coredns:coredns /etc/coredns /var/lib/coredns

# --- STAGE 4: Install Runtime Utilities ---
{util_packages}

# Expose standard DNS ports
EXPOSE 53/tcp
EXPOSE 53/udp

# Expose health check port (optional)
EXPOSE 8080/tcp
EXPOSE 8181/tcp

# Change the Work Dir
WORKDIR /etc/coredns

# Set default user
USER coredns

# Define default command
# CMD ["coredns", "-conf", "/etc/coredns/Corefile"]